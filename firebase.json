{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "node -e \"require('fs').copyFileSync('content/recruitment-faq.md','functions/knowledge.md')\"",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "trailingSlash": true,
    "cleanUrls": false,
    "rewrites": [
      {
        "source": "/api/recruitment-chat",
        "function": "recruitmentChat"
      }
    ]
  }
}
